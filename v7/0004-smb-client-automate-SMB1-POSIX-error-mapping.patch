From 917753fba10c1e53bbad98b3aa246878e3739705 Mon Sep 17 00:00:00 2001
From: Huiwen He <hehuiwen@kylinos.cn>
Date: Mon, 9 Mar 2026 15:41:16 +0800
Subject: [PATCH 4/8] smb/client: automate SMB1 POSIX error mapping

Extend the 'gen_smb1_mapping' script to support generating POSIX error
mapping tables for both ERRDOS and ERRSRV classes. The script parses
annotations from 'smberr.h' and generates sorted mapping arrays at
compile time.

This ensures that the mapping logic remains synchronized with the
source headers and facilitates faster error mapping lookups via future
binary search implementation.

Update the Makefile to generate 'smberr_dos_map.c' and 'smberr_srv_map.c'.
Modify 'smb1maperror.c' to use these generated tables, allowing for the
removal of the manual 'mapping_table_ERRDOS' and 'mapping_table_ERRSRV'
arrays.

Signed-off-by: Huiwen He <hehuiwen@kylinos.cn>
Reviewed-by: ChenXiaoSong <chenxiaosong@kylinos.cn>
---
 fs/smb/client/Makefile         | 10 ++++-
 fs/smb/client/gen_smb1_mapping | 25 ++++++++++-
 fs/smb/client/smb1maperror.c   | 77 +---------------------------------
 3 files changed, 34 insertions(+), 78 deletions(-)

diff --git a/fs/smb/client/Makefile b/fs/smb/client/Makefile
index 959cb92e3eb0..8b5a6a884226 100644
--- a/fs/smb/client/Makefile
+++ b/fs/smb/client/Makefile
@@ -47,11 +47,19 @@ cifs-$(CONFIG_CIFS_COMPRESSION) += compress.o compress/lz77.o
 #
 # Build the SMB1 error mapping tables from nterr.h
 #
-smb1-generated-y := smb1_mapping_table.c
+smb1-generated-y := smb1_mapping_table.c \
+                    smberr_dos_map.c \
+                    smberr_srv_map.c
 
 $(obj)/smb1_mapping_table.c: $(src)/nterr.h $(src)/gen_smb1_mapping FORCE
 	$(call if_changed,gen_smb1_mapping)
 
+$(obj)/smberr_dos_map.c: $(src)/smberr.h $(src)/gen_smb1_mapping FORCE
+	$(call if_changed,gen_smb1_mapping)
+
+$(obj)/smberr_srv_map.c: $(src)/smberr.h $(src)/gen_smb1_mapping FORCE
+	$(call if_changed,gen_smb1_mapping)
+
 $(obj)/smb1maperror.o: $(addprefix $(obj)/, $(smb1-generated-y))
 
 quiet_cmd_gen_smb1_mapping = GEN     $@
diff --git a/fs/smb/client/gen_smb1_mapping b/fs/smb/client/gen_smb1_mapping
index 8a3576205821..436c62c8090c 100644
--- a/fs/smb/client/gen_smb1_mapping
+++ b/fs/smb/client/gen_smb1_mapping
@@ -14,6 +14,7 @@ my $out_file = shift || die "Usage: $0 <in-file> <out-file>";
 my $input_name  = (split m|/|, $in_file)[-1];
 my $script_name = (split m|/|, $0)[-1];
 my @list     = ();
+my $current_class = "";
 
 # Parse annotated entries from the input file
 open(my $in, "<", $in_file) or die "Cannot open $in_file: $!";
@@ -29,6 +30,17 @@ if ($in_file =~ /nterr\.h$/) {
 			push @list, { val => $val, name => $name, class => $class, code => $code };
 		}
 	}
+} elsif ($in_file =~ /smberr\.h$/) {
+	while (<$in>) {
+		if (/generated with the (\w+) error class/) {
+			$current_class = $1;
+		}
+		if (/^\s*#define\s+(ERR[A-Za-z0-9_]+)\s+([0-9a-fA-FxX]+)\s*\/\/\s*(-[A-Z0-9_]+)/) {
+			my ($name, $val_str, $error) = ($1, $2, $3);
+			my $val = ($val_str =~ /^0x/i) ? hex($val_str) : $val_str;
+			push @list, { val => $val, name => $name, error => $error, class => $current_class };
+		}
+	}
 }
 close($in);
 
@@ -38,7 +50,16 @@ close($in);
 # Generate the C mapping table output
 open(my $out, ">", $out_file) or die "Cannot open $out_file: $!";
 print $out "/* Autogenerated from $input_name by $script_name */\n\n";
-foreach my $e (@list) {
-	printf $out "\t{ %s, %s, %s, \"%s\" },\n", $e->{class}, $e->{code}, $e->{name}, $e->{name};
+if ($in_file =~ /nterr\.h$/) {
+	foreach my $e (@list) {
+		printf $out "\t{ %s, %s, %s, \"%s\" },\n", $e->{class}, $e->{code}, $e->{name}, $e->{name};
+	}
+} elsif ($in_file =~ /smberr\.h$/) {
+	my $filter = ($out_file =~ /dos/) ? "ERRDOS" : ($out_file =~ /srv/ ? "ERRSRV" : "");
+	foreach my $e (@list) {
+		if (!$filter || $e->{class} eq $filter) {
+			printf $out "\t{%s, %s},\n", $e->{name}, $e->{error};
+		}
+	}
 }
 close($out);
diff --git a/fs/smb/client/smb1maperror.c b/fs/smb/client/smb1maperror.c
index 59229415c444..5cc27b52e7d8 100644
--- a/fs/smb/client/smb1maperror.c
+++ b/fs/smb/client/smb1maperror.c
@@ -20,85 +20,12 @@ struct smb_to_posix_error {
 };
 
