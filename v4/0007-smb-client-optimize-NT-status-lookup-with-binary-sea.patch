From 54fd1b6ccda3f23166ffe76470de82190f8b7b84 Mon Sep 17 00:00:00 2001
From: Huiwen He <hehuiwen@kylinos.cn>
Date: Mon, 16 Feb 2026 17:12:51 +0800
Subject: [PATCH 7/7] smb: client: optimize NT status lookup with binary search

The ntstatus_to_dos_map[] table is sorted. Replace the linear search with
binary search to improve lookup performance.

Also remove the sentinel entry as it is no longer needed with ARRAY_SIZE().

Signed-off-by: Huiwen He <hehuiwen@kylinos.cn>
---
 fs/smb/client/smb1maperror.c | 16 +++++++++++-----
 1 file changed, 11 insertions(+), 5 deletions(-)

diff --git a/fs/smb/client/smb1maperror.c b/fs/smb/client/smb1maperror.c
index e7c8720fdef4..f1ddc68da955 100644
--- a/fs/smb/client/smb1maperror.c
+++ b/fs/smb/client/smb1maperror.c
@@ -34,17 +34,23 @@ static const struct smb_to_posix_error mapping_table_ERRSRV[] = {
 /* NT status -> dos error map */
 static const struct nt_err_code_struct ntstatus_to_dos_map[] = {
 #include "smb1_mapping_table.c"
-	{0, 0, 0, NULL}
 };
 
 static const struct nt_err_code_struct *
 ntstatus_to_dos(__u32 ntstatus)
 {
-	int i;
+	int low = 0, high = ARRAY_SIZE(ntstatus_to_dos_map) - 1;
 
-	for (i = 0; ntstatus_to_dos_map[i].nt_errstr; i++) {
-		if (ntstatus == ntstatus_to_dos_map[i].ntstatus)
-			return &ntstatus_to_dos_map[i];
+	while (low <= high) {
+		int mid = low + (high - low) / 2;
+
+		if (ntstatus_to_dos_map[mid].ntstatus == ntstatus)
+			return &ntstatus_to_dos_map[mid];
+
+		if (ntstatus_to_dos_map[mid].ntstatus < ntstatus)
+			low = mid + 1;
+		else
+			high = mid - 1;
 	}
 	return NULL;
 }
