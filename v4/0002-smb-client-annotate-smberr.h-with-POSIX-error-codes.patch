Date: Mon, 16 Feb 2026 14:50:18 +0800
Subject: [PATCH 2/7] smb/client: annotate smberr.h with POSIX error codes

Annotate SMB1 error definitions in smberr.h with their corresponding
POSIX error codes.

To facilitate automated processing, existing human-readable comments in
smberr.h were first moved to the line preceding the #define statements.

This provides the source data for generating sorted mapping tables,
allowing the implementation of binary search for faster error mapping
lookups in later commits.

The annotations were performed based on the manual
'mapping_table_ERRDOS' and 'mapping_table_ERRSRV' arrays in
smb1maperror.c using the following script:

import re

MAP_FILE = "fs/smb/client/smb1maperror.c"
SMBERR_FILE = "fs/smb/client/smberr.h"

def move_comments(file_path):
    with open(file_path, "r") as f:
        lines = f.readlines()
    new_lines = []
    pattern = re.compile(r'^(\s*#define\s+[A-Za-z0-9_]+\s+.*?)\s*(/\*.*?\*/|//.*)$')
    for line in lines:
        match = pattern.match(line.rstrip())
        if match:
            define_part, comment_part = match.groups()
            indent = " " * (len(line) - len(line.lstrip()))
            new_lines.append(indent + comment_part + "
")
            new_lines.append(define_part.rstrip() + "
")
        else:
            new_lines.append(line)
    with open(file_path, "w") as f:
        f.writelines(new_lines)

def annotate_smberr():
    mapping = {}
    with open(MAP_FILE, "r") as f:
        content = f.read()
        for table in ["mapping_table_ERRDOS", "mapping_table_ERRSRV"]:
            start = content.find(table)
            if start == -1: continue
            end = content.find("};", start)
            block = content[start:end]
            matches = re.findall(r'\{\s*([A-Za-z0-9_]+)\s*,\s*(-[A-Z0-9_]+)\s*\}', block)
            for name, posix in matches:
                mapping[name] = posix
    with open(SMBERR_FILE, "r") as f:
        lines = f.readlines()
    new_lines = []
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("#define "):
            parts = stripped.split()
            if len(parts) >= 2:
                name = parts[1]
                if name in mapping:
                    line = f"{line.rstrip():<31} // {mapping[name]}
"
        new_lines.append(line)
    with open(SMBERR_FILE, "w") as f:
        f.writelines(new_lines)

move_comments(SMBERR_FILE)
annotate_smberr()

